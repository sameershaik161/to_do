// ✅ EXCELLENT: Complete RTK Query configuration
export const taskApi = createApi({
  reducerPath: 'taskApi',
  baseQuery: fetchBaseQuery({ baseUrl: 'http://localhost:5000/api' }),
  tagTypes: ['Task'], // Cache invalidation tags
  
  endpoints: (builder) => ({
    // ✅ Query with caching and transformation
    getTasks: builder.query<Task[], void>({
      query: () => '/tasks',
      transformResponse: (response: ApiResponse<Task[]>) => response.data,
      providesTags: (result) =>
        result
          ? [
              ...result.map(({ _id }) => ({ type: 'Task' as const, id: _id })),
              { type: 'Task', id: 'LIST' },
            ]
          : [{ type: 'Task', id: 'LIST' }],
    }),
    
    // ✅ Mutation with automatic cache invalidation
    updateTask: builder.mutation<Task, { id: string; data: UpdateTaskDto }>({
      query: ({ id, data }) => ({
        url: `/tasks/${id}`,
        method: 'PUT',
        body: data,
      }),
      invalidatesTags: (_result, _error, { id }) => [
        { type: 'Task', id },        // Invalidate specific task
        { type: 'Task', id: 'LIST' }, // Invalidate task list
      ],
    }),
  }),
});
```

