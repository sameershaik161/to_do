// ✅ EXCELLENT: Consistent error handling pattern
export const createTask = async (req: Request, res: Response): Promise<void> => {
  try {
    const body = req.body as CreateTaskDto;
    const task = await Task.create(body);
    res.status(201).json({ success: true, data: task }); // ✅ 201 for creation
  } catch (error: unknown) {
    // ✅ Type-safe error handling
    if (error instanceof Error && error.name === 'ValidationError') {
      res.status(400).json({ success: false, message: error.message }); // ✅ 400 for validation
    } else {
      res.status(500).json({ success: false, message: 'Server error', error }); // ✅ 500 for server errors
    }
  }
};

// ✅ EXCELLENT: Consistent 404 handling
export const getTaskById = async (req: Request, res: Response): Promise<void> => {
  try {
    const task = await Task.findById(req.params['id']);
    if (!task) {
      res.status(404).json({ success: false, message: 'Task not found' }); // ✅ 404 for not found
      return; // ✅ Early return
    }
    res.json({ success: true, data: task }); // ✅ 200 for success
  } catch (error) {
    res.status(500).json({ success: false, message: 'Server error', error });
  }
};
```

